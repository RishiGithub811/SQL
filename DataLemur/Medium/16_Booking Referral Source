WITH cte AS (
    SELECT 
        channel,
        COUNT(*) AS channel_booking
    FROM (
        SELECT 
            b.booking_id,
            b.user_id,
            b.booking_date,
            b1.channel,
            DENSE_RANK() OVER (
                PARTITION BY b.user_id 
                ORDER BY b.booking_date
            ) AS rnk
        FROM bookings b
        LEFT JOIN booking_attribution b1 
        ON b.booking_id = b1.booking_id
    ) t
    WHERE rnk = 1
    GROUP BY channel
)

SELECT 
   channel,
    ROUND(
       100.0 * channel_booking / 
       (SELECT SUM(channel_booking) FROM cte), 
    0) AS first_booking_pct
FROM cte
WHERE channel IS NOT NULL
ORDER BY first_booking_pct DESC
LIMIT 1;
